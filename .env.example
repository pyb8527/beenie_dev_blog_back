# dev/prod 프로필 실행 시 필요한 환경변수 예시.
# 실제 값을 채운 뒤 .env로 복사해서 사용한다. (.env는 git에 커밋하지 않는다)

DB_URL=jdbc:mysql://localhost:3307/backend_init
DB_USERNAME=root
DB_PASSWORD=root

REDIS_HOST=localhost
REDIS_PORT=6379

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-please-0123456789abcdef
JWT_ACCESS_EXPIRATION=1800000
JWT_REFRESH_EXPIRATION=1209600000

# GitHub OAuth2 (https://github.com/settings/developers 에서 OAuth App 생성 후 채울 것)
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
ALLOWED_GITHUB_ID=your-github-numeric-or-login-id

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=beenie-blog
S3_REGION=us-east-1

# App
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
